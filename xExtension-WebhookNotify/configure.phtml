<?php
/** @var WebhookNotifyExtension $this */
$config = $this->getUserConfiguration();

// Migrate legacy config for display
if (!isset($config['webhooks']) && !empty($config['webhook_url'])) {
	$config['webhooks'] = [
		['type' => 'generic', 'url' => $config['webhook_url'], 'enabled' => true],
	];
}
$webhooks = $config['webhooks'] ?? [];
$feedFilter = htmlspecialchars($config['feed_filter'] ?? '', ENT_QUOTES, 'UTF-8');
$feedExclude = htmlspecialchars($config['feed_exclude'] ?? '', ENT_QUOTES, 'UTF-8');
$timeout = (int)($config['timeout'] ?? 10);
